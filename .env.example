# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── MySQL (Local) ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=github_analyzer

# ─── GitHub Personal Access Token (strongly recommended) ──────────────────────
# Without a token: 60 requests/hour
# With a token:  5000 requests/hour
#
# How to get one:
#   1. Go to https://github.com/settings/tokens
#   2. Click "Generate new token (classic)"
#   3. Give it a name, set no expiry (or 90 days)
#   4. Select scope: (none needed for public data)
#   5. Copy and paste the token below
#
GITHUB_TOKEN=your_github_personal_access_token_here

# ─── Railway (auto-provided when you add MySQL plugin — do not edit) ───────────
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=
